# Matrix homeserver URL (use the container-accessible address)
MATRIX_HOMESERVER=https://matrix.example.com
# Bot's full Matrix user ID
MATRIX_BOT_USER=@dicebot:example.com
# Bot's password
MATRIX_BOT_PASSWORD=changeme
# Command prefix (default: !roll)
COMMAND_PREFIX=!roll
# Device display name
DEVICE_NAME=DiceBot
# Path to persist the mxc:// image cache (survives restarts)
CACHE_FILE=/app/data/mxc_cache.json
